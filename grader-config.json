{
  "schemaVersion": "1.0",
  "templateSlug": "gpi-docker-containerization",
  "evaluationBlocks": [
    {
      "blockId": "auto",
      "evaluationType": "automated_pipeline",
      "metrics": [
        {
          "metricKey": "config_file_exists",
          "worker": "ConfigWorker",
          "weight": 15,
          "threshold": 1.0,
          "config": {
            "patterns": ["Dockerfile", "docker-compose.yml", ".dockerignore"]
          }
        },
        {
          "metricKey": "config_file_valid_schema",
          "worker": "ConfigWorker",
          "weight": 20,
          "threshold": 1.0,
          "config": {
            "validator": "docker-compose",
            "target": "docker-compose.yml",
            "requiredServices": ["app", "db", "redis"]
          }
        },
        {
          "metricKey": "docker_image_builds",
          "worker": "DockerWorker",
          "weight": 30,
          "threshold": 1.0,
          "config": {
            "dockerfile": "Dockerfile",
            "context": ".",
            "tag": "workshop-app"
          }
        },
        {
          "metricKey": "docker_image_size_mb",
          "worker": "DockerWorker",
          "weight": 20,
          "threshold": 250,
          "config": {
            "tag": "workshop-app",
            "maxSizeMB": 250
          }
        },
        {
          "metricKey": "ci_pipeline_passes",
          "worker": "GitHubApiWorker",
          "weight": 15,
          "threshold": 1.0,
          "config": {
            "checkRunName": "build",
            "requireAllPassing": true
          }
        }
      ]
    }
  ]
}
